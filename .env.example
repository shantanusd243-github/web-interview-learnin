# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/javaprep?retryWrites=true&w=majority

# Comma-separated list of allowed frontend origins (Vercel URL + local dev)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# JWT secret - MUST be a long random string (256+ bits) in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ACCESS_EXP_MS=900000
JWT_REFRESH_EXP_MS=604800000

# Bootstrap admin account - created automatically on first boot if it doesn't exist
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!

PORT=8080
